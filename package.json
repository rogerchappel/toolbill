{
  "name": "toolbill",
  "version": "0.1.0",
  "description": "Local-first CLI bill of materials for coding-agent logs and git changes.",
  "type": "module",
  "bin": {
    "toolbill": "./dist/src/cli.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "fixtures",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/test/*.test.js",
    "smoke": "npm run build && node dist/src/cli.js --help && node dist/src/cli.js summarize fixtures/openclaw-text.log && node dist/src/cli.js json fixtures/codex-jsonl.log",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent-observability",
    "cli",
    "codex",
    "git",
    "jsonl",
    "local-first",
    "logs"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/toolbill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/toolbill/issues"
  },
  "homepage": "https://github.com/rogerchappel/toolbill#readme"
}
